# DecentraLabs Lab Gateway - Full Version Environment Configuration
# This file contains all environment variables for the full version with auth2 service

# =============================================================================
# BASIC CONFIGURATION
# =============================================================================

# Server configuration
SERVER_NAME=localhost
HTTPS_PORT=443
HTTP_PORT=80
# Optional JWT issuer override expected by OpenResty (must match token iss exactly).
# Leave empty to auto-build as https://<SERVER_NAME>[:<HTTPS_PORT>]/auth.
# If set to an external Full issuer (Lite mode), the gateway auto-syncs the JWT public key
# from https://<issuer-origin>/.well-known/public-key.pem.
# Lite mode disables local auth/treasury/intents endpoints in this gateway instance,
# but lab access and FMU access still work with JWTs issued by that external issuer.
ISSUER=

# OpenResty bind address (127.0.0.1 for local-only, 0.0.0.0 for public)
OPENRESTY_BIND_ADDRESS=127.0.0.1
# OpenResty bind ports (local ports on the host)
OPENRESTY_BIND_HTTPS_PORT=443
OPENRESTY_BIND_HTTP_PORT=80

# Host UID/GID for bind mounts (Linux/macOS)
# setup.sh will auto-fill these values.
HOST_UID=1000
HOST_GID=1000

# =============================================================================
# MYSQL DATABASE CONFIGURATION
# =============================================================================

MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=guacamole_db
MYSQL_USER=guacamole_user
MYSQL_PASSWORD=CHANGE_ME
# Optional override for blockchain-services schema
BLOCKCHAIN_MYSQL_DATABASE=blockchain_services

# =============================================================================
# GUACAMOLE CONFIGURATION
# =============================================================================

GUAC_ADMIN_USER=guacadmin
GUAC_ADMIN_PASS=CHANGE_ME
AUTO_LOGOUT_ON_DISCONNECT=true

# =============================================================================
# TLS / CERTBOT CONFIGURATION
# =============================================================================

# Let's Encrypt / certbot - optional automation for obtaining real TLS certificates.
# Comma-separated list of domains and an email for ACME. Leave empty if using self-signed/dev.
CERTBOT_DOMAINS=
CERTBOT_EMAIL=
#CERTBOT_STAGING=0

# =============================================================================
# CLOUDFLARE TUNNEL
# =============================================================================

# This configuration is optional - to expose the gateway without public IP
# Start the sidecar with compose profile: --profile cloudflare or --profile cloudflare-token
# If you have a token from a Cloudflare tunnel, paste it below. If empty, a Quick Tunnel will be used.
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# SECRETS AND KEYS
# =============================================================================

# Lab Manager access token (used by /lab-manager and /ops).
# Set to empty to disable /ops endpoints (and keep /lab-manager private-network-only).
LAB_MANAGER_TOKEN=CHANGE_ME
LAB_MANAGER_TOKEN_HEADER=X-Lab-Manager-Token
LAB_MANAGER_TOKEN_COOKIE=lab_manager_token

# Admin access token
# Used by /wallet, /billing, /wallet-dashboard and /billing/admin/** (sent by OpenResty).
# Backwards-compatible: TREASURY_TOKEN is still accepted as a fallback.
ADMIN_ACCESS_TOKEN=CHANGE_ME
ADMIN_ACCESS_TOKEN_HEADER=X-Access-Token
ADMIN_ACCESS_TOKEN_COOKIE=access_token
ADMIN_ACCESS_TOKEN_REQUIRED=true
ADMIN_DASHBOARD_LOCAL_ONLY=true
ADMIN_ALLOWED_CIDRS=
SECURITY_ALLOW_PRIVATE_NETWORKS=false
ADMIN_DASHBOARD_ALLOW_PRIVATE=false
# Set to false when OpenResty is the public edge (no upstream load-balancer).
# When false, X-Forwarded-For and X-Real-IP headers are NOT trusted for
# access-control decisions, preventing internal clients from impersonating
# external IPs.  Default: true (trust XFF from a private upstream proxy).
ADMIN_TRUST_FORWARDED_IP=true

# =============================================================================
# CORS CONFIGURATION (OpenResty)
# =============================================================================

# Comma-separated list of allowed origins for browser clients.
# Default includes the DecentraLabs Marketplace. Add your own origins as needed.
# Leave empty to use MARKETPLACE_URL as the only allowed origin (recommended).
CORS_ALLOWED_ORIGINS=

# Blockchain-specific settings (CONTRACT_ADDRESS, ETHEREUM_*_RPC_URL,
# ETHEREUM_GAS_LIMIT_CONTRACT, ALLOWED_ORIGINS, MARKETPLACE_PUBLIC_KEY_URL, etc.)
# belong in blockchain-services/.env.

# =============================================================================
# FMU RUNNER CONFIGURATION
# =============================================================================

# Active FMU backend mode:
# - local: Gateway executes provisioned FMUs from ./fmu-data (dev/test)
# - station: Gateway uses Lab Station internal endpoints (production target)
FMU_BACKEND_MODE=local

# Enable FMU runner integration in OpenResty:
# - false: /fmu and FMU AAS sync routes are disabled, and OpenResty starts without fmu-runner
# - true: /fmu and FMU AAS sync routes are active and proxied to fmu-runner
# - empty: treated as enabled
# FMU runner starts unless FMU_RUNNER_ENABLED is explicitly set to false.
FMU_RUNNER_ENABLED=

# Maximum simulation execution time in seconds (per request)
FMU_MAX_SIMULATION_TIMEOUT=300

# Maximum concurrent simulation executions per FMU model
FMU_MAX_CONCURRENT_PER_MODEL=10

# Proxy download rate limit (requests/min per user+lab)
FMU_PROXY_DOWNLOAD_RATE_LIMIT_PER_MINUTE=20

# Realtime session.create rate limit (requests/min per subject/ticket+ip)
FMU_WS_CREATE_RATE_LIMIT_PER_MINUTE=30

# Optional fixed WS URL for generated proxy config
FMU_PROXY_GATEWAY_WS_URL=

# Optional HMAC key to sign generated proxy artifacts
FMU_PROXY_SIGNING_KEY=

# Lab Station backend configuration (used when FMU_BACKEND_MODE=station)
FMU_STATION_BASE_URL=
FMU_STATION_INTERNAL_TOKEN=
FMU_STATION_REQUEST_TIMEOUT=10

# Optional internal token for blockchain-services ticket issue/redeem endpoints
AUTH_SESSION_TICKET_INTERNAL_TOKEN=

# =============================================================================
# AAS (Asset Administration Shell) — Full Gateway only
# =============================================================================

# AAS server URL used by fmu-runner, ops-worker and OpenResty (/aas/*) to reach
# the AAS Environment API.
#
# Option A — Bundled BaSyx (default for Full Gateway):
#   Leave empty. The internal default http://basyx-aas-server:8081 is used.
#   Activate the bundled containers with: docker compose --profile aas up
#   (or COMPOSE_PROFILES=aas). setup.sh / setup.bat handle this automatically.
#
# Option B — External AAS server (BaSyx, NOVAAS, or any AAS V3 REST API):
#   Set to the base URL reachable from inside the Docker stack.
#   The bundled basyx-aas-server and basyx-mongo containers are NOT needed.
#   Omit --profile aas from the compose command.
#   Examples:
#     BASYX_AAS_URL=http://192.168.1.10:8081
#     BASYX_AAS_URL=https://my-aas-server.example.com
#   Note: HTTPS upstreams must present a valid certificate; use HTTP for
#   internal/LAN servers without a CA-signed cert.
#
# Option C — No AAS support:
#   Leave empty and omit --profile aas. AAS sync endpoints return
#   {"disabled": true} gracefully; /aas/* will return 502 (no upstream).
#
BASYX_AAS_URL=
